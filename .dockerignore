# Reduce Docker build context - exclude bloat
node_modules/
.git/
.gitignore
*.md
!README.md

# Build outputs
dist/
.next/
*.tsbuildinfo

# Environment and secrets
.env
.env.*
.firebase/
serviceAccountKey*.json
*-debug.log

# Note: agegate-worker/ must NOT be excluded - RunPod GitHub builds use repo root context
# and need agegate-worker/ for the worker Dockerfile. API build ignores it via Dockerfile.

# Large or unnecessary files
*.mmdb
tt
